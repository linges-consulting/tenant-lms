# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=lms_user
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=lms_db

# ── JWT Secrets (generate each with: openssl rand -hex 32) ────────────────
# REQUIRED: replace all "change-me" values before deploying to production
JWT_ROOT_SECRET=change-me
EXTERNAL_JWT_SECRET=change-me
INTERNAL_JWT_SECRET=change-me
INTERNAL_API_KEY=change-me
INTERNAL_SERVICE_SECRET=change-me

# ── Token Lifecycle ───────────────────────────────────────────────────────────
# Access token expiry in minutes (default: 30 min — do not increase in prod)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Development default includes Vite dev server and localhost
# Production: set to your actual frontend domain, e.g. https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ── Mailgun ──────────────────────────────────────────────────────────────────
USE_MAILGUN=False
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_BASE_URL=https://api.mailgun.net
FROM_EMAIL=noreply@yourdomain.com
MAILGUN_AUTHORIZED_RECIPIENT=

# ── App ──────────────────────────────────────────────────────────────────────
# Set to "production" to disable OpenAPI docs and enable production hardening
ENVIRONMENT=development
FRONTEND_URL=http://localhost

# ── Login Security ────────────────────────────────────────────────────────────
# Temporary lockout after this many consecutive failures (per account)
LOGIN_MAX_ATTEMPTS=5
# How long the temp lockout lasts (minutes)
LOGIN_LOCKOUT_MINUTES=15
# Permanent lockout (force password reset) after this many total failures
LOGIN_FORCE_RESET_ATTEMPTS=10

# ── Redis Cache TTLs ─────────────────────────────────────────────────────────
# All values in seconds. Reduce during development to see changes immediately.
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=600
CACHE_TTL_LONG=1800

# ── SCORM ────────────────────────────────────────────────────────────────────
SCORM_MAX_UPLOAD_MB=250

# ── Production Seed ───────────────────────────────────────────────────────────
# Initial SysAdmin account created on first deploy (idempotent)
SEED_ADMIN_EMAIL=admin@cpvmtraining.com
SEED_ADMIN_PASSWORD=change-me-in-prod

# ── Production Deployment (server .env only) ──────────────────────────────────
# Public-facing domain (must have an A record pointing at this server before first deploy)
FRONTEND_DOMAIN=cpvmtraining.com
# Email for Let's Encrypt certificate expiry notifications
LETSENCRYPT_EMAIL=admin@cpvmtraining.com
